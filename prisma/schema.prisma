generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BbtUnit {
  C
  F
}

enum MucusTransparency {
  X
  C
  K
}

enum MucusSlipperiness {
  X
  N
  L
}

enum MostFertileFrequency {
  NONE
  ONE
  TWO
  THREE
  AD
}

enum CervixPosition {
  low
  medium
  high
  unknown
}

enum FertilityStatus {
  fertile
  non_fertile
  uncertain
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  settings     UserSettings?
  cycles       Cycle[]
  sessions     Session[]
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  preferredUnit        BbtUnit  @default(C)
  cycleLengthHint      Int?
  lutealLengthHint     Int?
  tempRiseThresholdC   Float    @default(0.2)
  disclaimerAcceptedAt DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Cycle {
  id                        String             @id @default(cuid())
  userId                    String
  startDate                 DateTime
  endDate                   DateTime?
  isActive                  Boolean            @default(true)
  interpretationStale       Boolean            @default(false)
  interpretationStaleReason String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  days            DailyObservation[]
  interpretations InterpretationDay[]
  overrides       OverrideDay[]

  @@index([userId, isActive])
}

model DailyObservation {
  id                String            @id @default(cuid())
  cycleId           String
  date              DateTime
  cycleDay          Int?
  bbtCelsius        Float?
  mucusStretch      Int               @default(0)
  mucusTransparency MucusTransparency @default(X)
  mucusSlipperiness MucusSlipperiness @default(X)
  mostFertileFrequency MostFertileFrequency @default(NONE)
  cervixPosition    CervixPosition    @default(unknown)
  bleedingLevel     Int               @default(0)
  intercourse       Boolean           @default(false)
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  cycle Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([cycleId, date])
  @@index([cycleId, date])
}

model InterpretationDay {
  id             String          @id @default(cuid())
  cycleId        String
  date           DateTime
  status         FertilityStatus
  ruleTrace      Json
  reasonCodes    Json
  autoComputedAt DateTime        @default(now())

  cycle Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([cycleId, date])
  @@index([cycleId, date])
}

model OverrideDay {
  id               String          @id @default(cuid())
  cycleId          String
  date             DateTime
  overriddenStatus FertilityStatus
  reason           String
  overriddenAt     DateTime        @default(now())

  cycle Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([cycleId, date])
  @@index([cycleId, date])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
